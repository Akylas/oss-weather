<?xml version="1.0" encoding="utf-8"?>
<!--
    Fallback / placeholder string resources for widget UI and descriptions.

    These strings are referenced:
      • From appwidget-provider XML files (android:description="@string/...")
      • Directly from Kotlin composables via context.getString(R.string.*)

    The library AAR must declare these names so that all references compile
    correctly. At runtime the app's own strings.xml (generated by the
    NativeScript CLI from app/i18n/*.json) will OVERRIDE these values
    through Android's standard resource-merging mechanism, providing fully
    translated text for every supported locale.

    DO NOT translate here — add translations to app/i18n/<lang>.json instead.
-->
<resources>
    <!-- appwidget-provider descriptions (referenced via android:description) -->
    <string name="widget.simple.description">Current weather at a glance</string>
    <string name="widget.withdate.description">Weather with date and location</string>
    <string name="widget.withclock.description">Real-time clock with weather</string>
    <string name="widget.hourly.description">Next 24 hours forecast</string>
    <string name="widget.daily.description">Weekly weather forecast</string>
    <string name="widget.forecast.description">Detailed weather forecast</string>

    <!-- Runtime UI strings (referenced from WidgetComposables.kt) -->
    <string name="widget.loading">Loading\u2026</string>
    <string name="widget.error_loading">Error loading widget data</string>
    <string name="widget.tap_configure">Tap to configure</string>
    <string name="widget.no_location">No location set</string>
</resources>
