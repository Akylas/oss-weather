{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Widget Layout Schema",
    "description": "Cross-platform widget layout definition for weather widgets",
    "definitions": {
        "expression": { "type": "array", "description": "Mapbox expression" },
        "color": {
            "oneOf": [
                { "type": "string", "description": "Color reference: 'onSurface', 'onSurfaceVariant', 'primary', 'error', or hex '#RRGGBB'" },
                { "type": "array", "description": "Mapbox expression evaluating to color" }
            ]
        },
        "number": {
            "oneOf": [{ "type": "number" }, { "type": "array", "description": "Mapbox expression evaluating to number" }]
        },
        "string": {
            "oneOf": [{ "type": "string" }, { "type": "array", "description": "Mapbox expression evaluating to string" }]
        },
        "boolean": {
            "oneOf": [{ "type": "boolean" }, { "type": "array", "description": "Mapbox expression evaluating to boolean" }]
        },
        "dataBinding": {
            "type": "string",
            "description": "Data path for weather data binding, e.g., 'temperature', 'locationName', 'hourlyData[0].time'"
        },
        "sizeValue": {
            "oneOf": [
                { "type": "number", "description": "Fixed size in dp/points" },
                { "type": "string", "pattern": "^\\d+(\\.\\d+)?%$", "description": "Percentage of parent" },
                { "type": "string", "enum": ["fill", "wrap", "auto"] }
            ]
        },
        "spacing": {
            "oneOf": [
                { "type": "number", "description": "Spacing in dp/points" },
                { "type": "array", "description": "Mapbox expression evaluating to spacing" }
            ]
        },
        "alignment": {
            "oneOf": [
                { "type": "string", "enum": ["start", "center", "end", "spaceBetween", "spaceAround", "spaceEvenly"] },
                { "type": "array", "description": "Mapbox expression evaluating to alignment" }
            ]
        },
        "crossAlignment": {
            "oneOf": [
                { "type": "string", "enum": ["start", "center", "end", "stretch"] },
                { "type": "array", "description": "Mapbox expression evaluating to crossAlignment" }
            ]
        },
        "fontWeight": {
            "oneOf": [
                { "type": "string", "enum": ["normal", "medium", "bold"] },
                { "type": "array", "description": "Mapbox expression evaluating to font weight" }
            ]
        },
        "textAlign": {
            "oneOf": [
                { "type": "string", "enum": ["left", "center", "right"] },
                { "type": "array", "description": "Mapbox expression evaluating to textAlign" }
            ]
        },
        "fontSize": {
            "oneOf": [{ "type": "number" }, { "type": "array", "description": "Mapbox expression evaluating to fontSize" }]
        },
        "baseElement": {
            "type": "object",
            "properties": {
                "id": { "type": "string", "description": "Optional element identifier" },
                "visible": { "type": "boolean", "default": true },
                "visibleIf": { "$ref": "#/definitions/string", "description": "Condition for visibility, e.g., 'size.width > 100'" },
                "platform": { 
                    "oneOf": [
                        { "type": "string", "enum": ["ios", "android", "nativescript"], "description": "Single platform this element is visible on" },
                        { "type": "array", "items": { "type": "string", "enum": ["ios", "android", "nativescript"] }, "description": "List of platforms this element is visible on" }
                    ],
                    "description": "Platform(s) where this element should be rendered. If not specified, element renders on all platforms"
                },
                "padding": { "$ref": "#/definitions/spacing" },
                "paddingHorizontal": { "$ref": "#/definitions/spacing" },
                "paddingVertical": { "$ref": "#/definitions/spacing" },
                "margin": { "$ref": "#/definitions/spacing" },
                "marginHorizontal": { "$ref": "#/definitions/spacing" },
                "marginVertical": { "$ref": "#/definitions/spacing" },
                "width": { "$ref": "#/definitions/sizeValue" },
                "height": { "$ref": "#/definitions/sizeValue" },
                "flex": { "type": "number", "description": "Flex weight for layout" },
                "backgroundColor": { "$ref": "#/definitions/color" },
                "cornerRadius": { "type": "number" }
            }
        },
        "column": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "column" },
                        "spacing": { "$ref": "#/definitions/spacing" },
                        "alignment": { "$ref": "#/definitions/alignment" },
                        "crossAlignment": { "$ref": "#/definitions/crossAlignment" },
                        "children": {
                            "type": "array",
                            "items": { "$ref": "#/definitions/element" }
                        }
                    },
                    "required": ["type", "children"]
                }
            ]
        },
        "row": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "row" },
                        "spacing": { "$ref": "#/definitions/spacing" },
                        "alignment": { "$ref": "#/definitions/alignment" },
                        "crossAlignment": { "$ref": "#/definitions/crossAlignment" },
                        "children": {
                            "type": "array",
                            "items": { "$ref": "#/definitions/element" }
                        }
                    },
                    "required": ["type", "children"]
                }
            ]
        },
        "stack": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "stack" },
                        "alignment": { "$ref": "#/definitions/crossAlignment" },
                        "children": {
                            "type": "array",
                            "items": { "$ref": "#/definitions/element" }
                        }
                    },
                    "required": ["type", "children"]
                }
            ]
        },
        "label": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "label" },
                        "text": { "$ref": "#/definitions/string" },
                        "fontSize": { "$ref": "#/definitions/number" },
                        "fontWeight": { "$ref": "#/definitions/fontWeight" },
                        "color": { "$ref": "#/definitions/color" },
                        "textAlign": { "$ref": "#/definitions/textAlign" },
                        "maxLines": { "$ref": "#/definitions/number" }
                    },
                    "required": ["type", "text"]
                }
            ]
        },
        "image": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "image" },
                        "src": { "$ref": "#/definitions/string" },
                        "size": { "$ref": "#/definitions/number" },
                        "tintColor": { "$ref": "#/definitions/color" },
                        "contentMode": { "type": "string", "enum": ["fit", "fill", "cover"] }
                    },
                    "required": ["type", "src"]
                }
            ]
        },
        "spacer": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "spacer" },
                        "size": { "$ref": "#/definitions/number" },
                        "flex": { "type": "number", "default": 1 }
                    },
                    "required": ["type"]
                }
            ]
        },
        "divider": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "divider" },
                        "thickness": { "type": "number", "default": 1 },
                        "color": { "$ref": "#/definitions/color" }
                    },
                    "required": ["type"]
                }
            ]
        },
        "scrollView": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "scrollView" },
                        "direction": { "type": "string", "enum": ["horizontal", "vertical"], "default": "vertical" },
                        "showIndicators": { "type": "boolean", "default": false },
                        "children": {
                            "type": "array",
                            "items": { "$ref": "#/definitions/element" }
                        }
                    },
                    "required": ["type", "children"]
                }
            ]
        },
        "forEach": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "forEach" },
                        "items": { "$ref": "#/definitions/string" },
                        "limit": { "$ref": "#/definitions/number" },
                        "itemTemplate": { "$ref": "#/definitions/element" }
                    },
                    "required": ["type", "items", "itemTemplate"]
                }
            ]
        },
        "conditional": {
            "type": "object",
            "properties": {
                "type": { "const": "conditional" },
                "condition": { "$ref": "#/definitions/expression", "description": "Condition expression, e.g., 'size.width > 200'" },
                "then": { "$ref": "#/definitions/element" },
                "else": { "$ref": "#/definitions/element" }
            },
            "required": ["type", "condition", "then"]
        },
        "clock": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "clock" },
                        "format24Hour": { "$ref": "#/definitions/string", "default": "HH:mm" },
                        "format12Hour": { "$ref": "#/definitions/string", "default": "h:mm a" },
                        "fontSize": { "$ref": "#/definitions/fontSize" },
                        "fontWeight": { "$ref": "#/definitions/fontWeight" },
                        "color": { "$ref": "#/definitions/color" }
                    },
                    "required": ["type"]
                }
            ]
        },
        "date": {
            "allOf": [
                { "$ref": "#/definitions/baseElement" },
                {
                    "type": "object",
                    "properties": {
                        "type": { "const": "date" },
                        "format": { "type": "string", "default": "EEEE, MMM d" },
                        "style": { "type": "string", "enum": ["date", "dayMonth", "fullDate", "year", "month"], "default": "date" },
                        "fontSize": { "type": "number" },
                        "fontWeight": { "$ref": "#/definitions/fontWeight" },
                        "color": { "$ref": "#/definitions/color" }
                    },
                    "required": ["type"]
                }
            ]
        },
        "element": {
            "oneOf": [
                { "$ref": "#/definitions/column" },
                { "$ref": "#/definitions/row" },
                { "$ref": "#/definitions/stack" },
                { "$ref": "#/definitions/label" },
                { "$ref": "#/definitions/image" },
                { "$ref": "#/definitions/spacer" },
                { "$ref": "#/definitions/divider" },
                { "$ref": "#/definitions/scrollView" },
                { "$ref": "#/definitions/forEach" },
                { "$ref": "#/definitions/conditional" },
                { "$ref": "#/definitions/clock" },
                { "$ref": "#/definitions/date" }
            ]
        }
    },
    "type": "object",
    "properties": {
        "name": { "type": "string", "description": "Widget name identifier" },
        "displayName": { "type": "string", "description": "Human-readable name" },
        "description": { "type": "string" },
        "background": {
            "type": "object",
            "properties": {
                "type": { "type": "string", "enum": ["solid", "gradient", "image"] },
                "color": { "$ref": "#/definitions/color" },
                "image": { "type": "string" }
            }
        },
        "layout": { "$ref": "#/definitions/element" },
        "variants": {
            "type": "array",
            "description": "Size-specific layout variants",
            "items": {
                "type": "object",
                "properties": {
                    "condition": { "$ref": "#/definitions/expression", "description": "Size condition, e.g., 'size.width < 120'" },
                    "layout": { "$ref": "#/definitions/element" }
                },
                "required": ["condition", "layout"]
            }
        }
    },
    "required": ["name", "layout"]
}
