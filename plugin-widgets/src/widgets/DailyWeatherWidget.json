{
    "$schema": "../../schema.json",
    "name": "DailyWeatherWidget",
    "displayName": "Daily Forecast",
    "description": "Shows daily weather forecast with high/low temperatures",
    "supportedSizes": [
        { "width": 160, "height": 300, "family": "large" },
        { "width": 260, "height": 400, "family": "large" }
    ],
    "defaultPadding": 8,
    "layout": {
        "type": "column",
        "alignment": "start",
        "crossAlignment": "stretch",
        "children": [
            {
                "type": "row",
                "alignment": "start",
                "crossAlignment": "start",
                "padding": 8,
                "fillWidth": true,
                "children": [
                    {
                        "type": "column",
                        "alignment": "start",
                        "crossAlignment": "start",
                        "children": [
                            {
                                "type": "label",
                                "text": ["get", "locationName"],
                                "fontSize": 12,
                                "opacity": 0.5,
                                "textAlign": "left",
                                "maxLines": 1
                            },
                            {
                                "type": "label",
                                "text": ["get", "temperature"],
                                "fontSize": 26,
                                "fontWeight": "bold",
                                "color": "onSurface"
                            }
                        ]
                    },
                    {
                        "type": "spacer",
                        "flex": 1
                    },
                    {
                        "type": "column",
                        "alignment": "end",
                        "crossAlignment": "end",
                        "children": [
                            {
                                "type": "image",
                                "src": ["get", "iconPath"],
                                "size": 54,
                                "visibleIf": ["has", "iconPath"]
                            },
                            {
                                "type": "label",
                                "text": ["get", "description"],
                                "fontSize": 11,
                                "opacity": 0.5,
                                "textAlign": "right",
                                "maxLines": 1,
                                "visibleIf": ["has", "description"]
                            }
                        ]
                    }
                ]
            },
            {
                "type": "column",
                "alignment": "start",
                "crossAlignment": "start",
                "fillWidth": true,
                "children": [
                    {
                        "type": "label",
                        "text": "daily",
                        "textAlign": "left",
                        "fontSize": 12,
                        "fontWeight": "medium",
                        "opacity": 0.5,
                        "paddingHorizontal": 8
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 4
            },
            {
                "type": "scrollView",
                "direction": "vertical",
                "showIndicators": false,
                "children": [
                    {
                        "type": "column",
                        "spacing": 0,
                        "children": [
                            {
                                "type": "forEach",
                                "items": "dailyData",
                                "limit": 10,
                                "itemTemplate": {
                                    "type": "column",
                                    "fillWidth": true,
                                    "padding": 2,
                                    "alignment": "center",
                                    "crossAlignment": "center",
                                    "children": [
                                        {
                                            "type": "column",
                                            "fillWidth": true,
                                            "paddingHorizontal": 6,
                                            "paddingVertical": 2,
                                            "backgroundColor": "surfaceVariant",
                                            "cornerRadius": 8,
                                            "alignment": "center",
                                            "crossAlignment": "center",
                                            "children": [
                                                {
                                                    "type": "row",
                                                    "fillWidth": true,
                                                    "alignment": "center",
                                                    "crossAlignment": "center",
                                                    "children": [
                                                        {
                                                            "type": "label",
                                                            "text": ["get", "item.day"],
                                                            "fontSize": 12,
                                                            "fontWeight": "medium",
                                                            "color": "onSurface",
                                                            "maxLines": 1
                                                        },
                                                        {
                                                            "type": "spacer",
                                                            "flex": 1
                                                        },
                                                        {
                                                            "type": "image",
                                                            "src": ["get", "item.iconPath"],
                                                            "size": 36
                                                        },
                                                        {
                                                            "type": "spacer",
                                                            "flex": 1
                                                        },
                                                        {
                                                            "type": "column",
                                                            "alignment": "end",
                                                            "crossAlignment": "end",
                                                            "children": [
                                                                {
                                                                    "type": "row",
                                                                    "alignment": "end",
                                                                    "crossAlignment": "center",
                                                                    "spacing": 6,
                                                                    "children": [
                                                                        {
                                                                            "type": "label",
                                                                            "text": ["get", "item.temperatureHigh"],
                                                                            "fontSize": 13,
                                                                            "fontWeight": "bold",
                                                                            "color": "onSurface",
                                                                            "maxLines": 1
                                                                        },
                                                                        {
                                                                            "type": "label",
                                                                            "text": ["get", "item.temperatureLow"],
                                                                            "fontSize": 11,
                                                                            "opacity": 0.5,
                                                                            "maxLines": 1
                                                                        }
                                                                    ]
                                                                },
                                                                {
                                                                    "type": "row",
                                                                    "alignment": "end",
                                                                    "crossAlignment": "center",
                                                                    "spacing": 6,
                                                                    "children": [
                                                                        {
                                                                            "type": "label",
                                                                            "text": ["get", "item.precipAccumulation"],
                                                                            "fontSize": 10,
                                                                            "opacity": 0.5,
                                                                            "visibleIf": ["has", "item.precipAccumulation"]
                                                                        },
                                                                        {
                                                                            "type": "label",
                                                                            "text": ["concat", "\ud83d\udca7", ["get", "item.precipitation"]],
                                                                            "fontSize": 10,
                                                                            "opacity": 0.5,
                                                                            "visibleIf": ["has", "item.precipitation"]
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                ]
            }
        ]
    },
    "generatePreviews": true,
    "preview": {
        "sizes": [
            { "width": 300, "height": 200 },
            { "width": 160, "height": 300 },
            { "width": 260, "height": 400 }
        ],
        "fakeData": {
