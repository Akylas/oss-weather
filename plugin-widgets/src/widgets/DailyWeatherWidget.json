{
    "$schema": "../schema.json",
    "name": "DailyWeatherWidget",
    "displayName": "Daily Forecast",
    "description": "Shows daily weather forecast with high/low temperatures",
    "supportedSizes": [
        {
            "width": 260,
            "height": 120,
            "family": "medium"
        },
        {
            "width": 260,
            "height": 200,
            "family": "large"
        }
    ],
    "defaultPadding": 8,
    "background": {
        "type": "solid",
        "color": "widgetBackground"
    },
    "layout": {
        "type": "column",
        "alignment": "start",
        "children": [
            {
                "type": "row",
                "alignment": "start",
                "crossAlignment": "start",
                "fillWidth": true,
                "paddingHorizontal": 8,
                "paddingTop": 8,
                "children": [
                    {
                        "type": "column",
                        "alignment": "start",
                        "crossAlignment": "start",
                        "children": [
                            {
                                "type": "label",
                                "text": ["get", "locationName"],
                                "fontSize": 12,
                                "color": "onSurfaceVariant",
                                "textAlign": "left",
                                "maxLines": 1
                            },
                            {
                                "type": "label",
                                "text": ["get", "temperature"],
                                "fontSize": 26,
                                "fontWeight": "bold",
                                "color": "onSurface"
                            }
                        ]
                    },
                    {
                        "type": "spacer",
                        "flex": 1
                    },
                    {
                        "type": "column",
                        "alignment": "end",
                        "crossAlignment": "end",
                        "children": [
                            {
                                "type": "image",
                                "src": ["get", "iconPath"],
                                "size": 54,
                                "visibleIf": ["has", "iconPath"]
                            },
                            {
                                "type": "label",
                                "text": ["get", "description"],
                                "fontSize": 11,
                                "color": "onSurfaceVariant",
                                "textAlign": "right",
                                "maxLines": 1,
                                "visibleIf": ["has", "description"]
                            }
                        ]
                    }
                ]
            },
            {
                "type": "row",
                "alignment": "start",
                "crossAlignment": "start",
                "paddingHorizontal": 8,
                "children": [
                    {
                        "type": "label",
                        "text": "daily",
                        "textAlign": "left",
                        "fontSize": 12,
                        "fontWeight": "medium",
                        "color": "onSurfaceVariant"
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 4
            },
            {
                "type": "scrollView",
                "direction": "vertical",
                "showIndicators": false,
                "children": [
                    {
                        "type": "forEach",
                        "items": "dailyData",
                        "limit": 10,
                        "itemTemplate": {
                            "type": "column",
                            "fillWidth": true,
                            "padding": 2,
                            "alignment": "center",
                            "crossAlignment": "center",
                            "children": [
                                {
                                    "type": "column",
                                    "fillWidth": true,
                                    "paddingHorizontal": 6,
                                    "paddingVertical": 2,
                                    "backgroundColor": "surfaceVariant",
                                    "cornerRadius": 8,
                                    "alignment": "center",
                                    "crossAlignment": "center",
                                    "children": [
                                        {
                                            "type": "row",
                                            "fillWidth": true,
                                            "alignment": "center",
                                            "crossAlignment": "center",
                                            "children": [
                                                {
                                                    "type": "label",
                                                    "text": ["get", "item.day"],
                                                    "fontSize": 12,
                                                    "fontWeight": "medium",
                                                    "color": "onSurface",
                                                    "maxLines": 1
                                                },
                                                {
                                                    "type": "spacer",
                                                    "flex": 1
                                                },
                                                {
                                                    "type": "image",
                                                    "src": ["get", "item.iconPath"],
                                                    "size": 36
                                                },
                                                {
                                                    "type": "spacer",
                                                    "flex": 1
                                                },
                                                {
                                                    "type": "column",
                                                    "alignment": "end",
                                                    "crossAlignment": "end",
                                                    "children": [
                                                        {
                                                            "type": "row",
                                                            "alignment": "end",
                                                            "crossAlignment": "center",
                                                            "spacing": 6,
                                                            "children": [
                                                                {
                                                                    "type": "label",
                                                                    "text": ["get", "item.temperatureHigh"],
                                                                    "fontSize": 13,
                                                                    "fontWeight": "bold",
                                                                    "color": "onSurface",
                                                                    "maxLines": 1
                                                                },
                                                                {
                                                                    "type": "label",
                                                                    "text": ["get", "item.temperatureLow"],
                                                                    "fontSize": 11,
                                                                    "color": "onSurfaceVariant",
                                                                    "maxLines": 1
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "type": "row",
                                                            "alignment": "end",
                                                            "crossAlignment": "center",
                                                            "spacing": 6,
                                                            "children": [
                                                                {
                                                                    "type": "label",
                                                                    "text": ["get", "item.precipAccumulation"],
                                                                    "fontSize": 10,
                                                                    "color": "onSurfaceVariant",
                                                                    "visibleIf": ["has", "item.precipAccumulation"]
                                                                },
                                                                {
                                                                    "type": "label",
                                                                    "text": ["concat", "\ud83d\udca7", ["get", "item.precipitation"]],
                                                                    "fontSize": 10,
                                                                    "color": "onSurfaceVariant",
                                                                    "visibleIf": ["has", "item.precipitation"]
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                ]
            }
        ]
    },
    "generatePreviews": true,
    "preview": {
        "sizes": [
            {"width": 160, "height": 300},
            {"width": 260, "height": 400}
        ],
        "fakeData": {
            "temperature": "12 \u00b0C",
            "locationName": "Grenoble",
            "description": "Partly Cloudy",
            "date": "Mon, Feb 24",
            "dailyData": [
                {
                    "day": "Mon",
                    "iconPath": "icon_themes/meteocons/images/800d.png",
                    "temperatureHigh": "12 \u00b0C",
                    "temperatureLow": "4 \u00b0C",
                    "precipAccumulation": "0 mm",
                    "precipitation": "5 %",
                    "windSpeed": "14 km/h"
                },
                {
                    "day": "Tue",
                    "iconPath": "icon_themes/meteocons/images/802d.png",
                    "temperatureHigh": "14 \u00b0C",
                    "temperatureLow": "6 \u00b0C",
                    "precipAccumulation": "0 mm",
                    "precipitation": "10 %",
                    "windSpeed": "12 km/h"
                },
                {
                    "day": "Wed",
                    "iconPath": "icon_themes/meteocons/images/500d.png",
                    "temperatureHigh": "10 \u00b0C",
                    "temperatureLow": "5 \u00b0C",
                    "precipAccumulation": "3 mm",
                    "precipitation": "60 %",
                    "windSpeed": "18 km/h"
                },
                {
                    "day": "Thu",
                    "iconPath": "icon_themes/meteocons/images/503.png",
                    "temperatureHigh": "9 \u00b0C",
