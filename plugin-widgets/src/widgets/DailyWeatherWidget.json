                    "precipAccumulation": "8 mm",
                    "precipitation": "80 %",
                    "windSpeed": "22 km/h"
                },
                {
                    "day": "Fri",
                    "iconPath": "icon_themes/meteocons/images/802d.png",
                    "temperatureHigh": "11 \u00b0C",
