{
    "$schema": "../../schema.json",
    "name": "ForecastWeatherWidget",
    "displayName": "Detailed Forecast",
    "description": "Shows current weather, hourly and daily forecasts",
    "supportedSizes": [
        { "width": 160, "height": 300, "family": "large" },
        { "width": 260, "height": 400, "family": "large" }
    ],
    "defaultPadding": 8,
    "layout": {
        "type": "column",
        "alignment": "start",
        "crossAlignment": "center",
        "children": [
            {
                "type": "row",
                "alignment": "start",
                "crossAlignment": "start",
                "paddingHorizontal": 10,
                "paddingVertical": 6,
                "fillWidth": true,
                "children": [
                    {
                        "type": "column",
                        "alignment": "start",
                        "crossAlignment": "start",
                        "children": [
                            {
                                "type": "label",
                                "text": ["get", "data.locationName"],
                                "fontSize": 12,
                                "opacity": 0.6,
                                "textAlign": "left",
                                "maxLines": 1
                            },
                            {
                                "type": "label",
                                "text": ["get", "data.temperature"],
                                "fontSize": 26,
                                "fontWeight": "bold",
                                "color": "onSurface"
                            }
                        ]
                    },
                    {
                        "type": "spacer",
                        "flex": 1
                    },
                    {
                        "type": "column",
                        "alignment": "end",
                        "crossAlignment": "end",
                        "children": [
                            {
                                "type": "image",
                                "src": ["get", "data.iconPath"],
                                "size": 54,
                                "visibleIf": ["has", "data.iconPath"]
                            },
                            {
                                "type": "label",
                                "text": ["get", "data.description"],
                                "fontSize": 11,
                                "opacity": 0.6,
                                "textAlign": "right",
                                "maxLines": 1,
                                "visibleIf": ["has", "data.description"]
                            }
                        ]
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 8
            },
            {
                "type": "column",
                "alignment": "start",
                "crossAlignment": "start",
                "fillWidth": true,
                "children": [
                    {
                        "type": "label",
                        "text": "hourly",
                        "textAlign": "left",
                        "fontSize": 12,
                        "fontWeight": "medium",
                        "opacity": 0.6,
                        "paddingHorizontal": 8
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 4
            },
            {
                "type": "scrollView",
                "direction": "horizontal",
                "showIndicators": false,
                "children": [
                    {
                        "type": "row",
                        "spacing": 0,
                        "children": [
                            {
                                "type": "forEach",
                                "items": "hourlyData",
                                "limit": 8,
                                "itemTemplate": {
                                    "type": "column",
                                    "alignment": "center",
                                    "crossAlignment": "center",
                                    "width": 53,
                                    "spacing": 2,
                                    "paddingHorizontal": 4,
                                    "children": [
                                        {
                                            "type": "label",
                                            "text": ["get", "item.time"],
                                            "fontSize": 10,
                                            "opacity": 0.6,
                                            "maxLines": 1
                                        },
                                        {
                                            "type": "image",
                                            "src": ["get", "item.iconPath"],
                                            "size": 28
                                        },
                                        {
                                            "type": "label",
                                            "text": ["get", "item.temperature"],
                                            "fontSize": 12,
                                            "fontWeight": "bold",
                                            "color": "onSurface",
                                            "maxLines": 1
                                        },
                                        {
                                            "type": "label",
                                            "text": ["get", "item.precipAccumulation"],
                                            "fontSize": 9,
                                            "opacity": 0.6,
                                            "visibleIf": ["has", "item.precipAccumulation"]
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 16
            },
            {
                "type": "column",
                "alignment": "start",
                "crossAlignment": "start",
                "fillWidth": true,
                "children": [
                    {
                        "type": "label",
                        "text": "daily",
                        "textAlign": "left",
                        "fontSize": 12,
                        "fontWeight": "medium",
                        "opacity": 0.6,
                        "paddingHorizontal": 8
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 4
            },
            {
                "type": "scrollView",
                "direction": "vertical",
                "showIndicators": false,
                "children": [
                    {
                        "type": "column",
                        "spacing": 0,
                        "children": [
                            {
                                "type": "forEach",
                                "items": "dailyData",
                                "limit": 10,
                                "itemTemplate": {
                                    "type": "column",
                                    "fillWidth": true,
                                    "padding": 2,
                                    "alignment": "center",
                                    "crossAlignment": "center",
                                    "children": [
                                        {
                                            "type": "column",
                                            "fillWidth": true,
                                            "paddingHorizontal": 6,
                                            "paddingVertical": 2,
                                            "backgroundColor": "surfaceVariant",
                                            "cornerRadius": 8,
                                            "alignment": "center",
                                            "crossAlignment": "center",
                                            "children": [
                                                {
                                                    "type": "row",
                                                    "fillWidth": true,
                                                    "alignment": "center",
                                                    "crossAlignment": "center",
                                                    "children": [
                                                        {
                                                            "type": "label",
                                                            "text": ["get", "item.day"],
                                                            "fontSize": 12,
                                                            "fontWeight": "medium",
                                                            "color": "onSurface",
                                                            "maxLines": 1
                                                        },
                                                        {
                                                            "type": "spacer",
                                                            "flex": 1
                                                        },
                                                        {
                                                            "type": "image",
                                                            "src": ["get", "item.iconPath"],
                                                            "size": 36
                                                        },
                                                        {
                                                            "type": "spacer",
                                                            "flex": 1
                                                        },
                                                        {
                                                            "type": "column",
                                                            "alignment": "end",
                                                            "crossAlignment": "end",
                                                            "children": [
                                                                {
                                                                    "type": "row",
                                                                    "alignment": "end",
                                                                    "crossAlignment": "center",
                                                                    "spacing": 6,
                                                                    "children": [
                                                                        {
                                                                            "type": "label",
                                                                            "text": ["get", "item.temperatureHigh"],
                                                                            "fontSize": 13,
                                                                            "fontWeight": "bold",
                                                                            "color": "onSurface",
                                                                            "maxLines": 1
                                                                        },
                                                                        {
                                                                            "type": "label",
                                                                            "text": ["get", "item.temperatureLow"],
                                                                            "fontSize": 13,
                                                                            "opacity": 0.6,
                                                                            "maxLines": 1
                                                                        }
                                                                    ]
                                                                },
                                                                {
                                                                    "type": "row",
                                                                    "alignment": "end",
                                                                    "crossAlignment": "center",
                                                                    "spacing": 6,
                                                                    "children": [
                                                                        {
                                                                            "type": "label",
                                                                            "text": ["get", "item.precipAccumulation"],
                                                                            "fontSize": 10,
                                                                            "opacity": 0.6,
                                                                            "visibleIf": ["has", "item.precipAccumulation"]
                                                                        },
                                                                        {
                                                                            "type": "label",
                                                                            "text": ["concat", "\ud83d\udca7", ["get", "item.precipitation"]],
                                                                            "fontSize": 10,
                                                                            "opacity": 0.6,
                                                                            "visibleIf": ["has", "item.precipitation"]
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                ]
            }
        ]
    },
    "generatePreviews": true,
    "preview": {
        "sizes": [
            { "width": 300, "height": 300 },
            { "width": 160, "height": 300 },
            { "width": 260, "height": 400 }
        ],
        "fakeData": {
            "temperature": "12\u00b0",
            "locationName": "Paris",
            "description": "Partly Cloudy",
            "iconPath": "800d",
            "date": "Mon, Feb 24",
            "hourlyData": [
                { "time": "06:00", "temperature": "6\u00b0", "iconPath": "800d", "precipAccumulation": "0 mm" },
                { "time": "07:00", "temperature": "7\u00b0", "iconPath": "800d", "precipAccumulation": "0 mm" },
                { "time": "08:00", "temperature": "8\u00b0", "iconPath": "802d", "precipAccumulation": "0 mm" },
                { "time": "09:00", "temperature": "10\u00b0", "iconPath": "500n", "precipAccumulation": "0 mm" },
                { "time": "10:00", "temperature": "12\u00b0", "iconPath": "802d", "precipAccumulation": "0 mm" },
                { "time": "11:00", "temperature": "13\u00b0", "iconPath": "802d", "precipAccumulation": "0 mm" }
            ],
            "dailyData": [
                { "day": "Mon", "iconPath": "800d", "temperatureHigh": "12\u00b0", "temperatureLow": "4\u00b0", "precipAccumulation": "0 mm" },
                { "day": "Tue", "iconPath": "802d", "temperatureHigh": "14\u00b0", "temperatureLow": "6\u00b0", "precipAccumulation": "0 mm" },
                { "day": "Wed", "iconPath": "500d", "temperatureHigh": "10\u00b0", "temperatureLow": "5\u00b0", "precipAccumulation": "0 mm" },
                { "day": "Thu", "iconPath": "802d", "temperatureHigh": "9\u00b0", "temperatureLow": "3\u00b0", "precipAccumulation": "0 mm" },
                { "day": "Fri", "iconPath": "800d", "temperatureHigh": "11\u00b0", "temperatureLow": "4\u00b0", "precipAccumulation": "0 mm" },
                { "day": "Sat", "iconPath": "803d", "temperatureHigh": "15\u00b0", "temperatureLow": "7\u00b0", "precipAccumulation": "0 mm" }
            ]
        }
    }
}
