{
    "$schema": "../schema.json",
    "name": "ForecastWeatherWidget",
    "displayName": "Detailed Forecast",
    "description": "Shows current weather, hourly and daily forecasts",
    "supportedSizes": [
        {
            "width": 260,
            "height": 200,
            "family": "medium"
        },
        {
            "width": 260,
            "height": 280,
            "family": "large"
        }
    ],
    "defaultPadding": 8,
    "background": {
        "type": "solid",
        "color": "widgetBackground"
    },
    "layout": {
        "type": "column",
        "alignment": "start",
        "crossAlignment": "center",
        "children": [
            {
                "type": "row",
                "alignment": "start",
                "crossAlignment": "start",
                "fillWidth": true,
                "paddingHorizontal": 8,
                "paddingTop": 8,
                "children": [
                    {
                        "type": "column",
                        "alignment": "start",
                        "crossAlignment": "start",
                        "children": [
                            {
                                "type": "label",
                                "text": ["get", "data.locationName"],
                                "fontSize": 12,
                                "color": "onSurfaceVariant",
                                "textAlign": "left",
                                "maxLines": 1
                            },
                            {
                                "type": "label",
                                "text": ["get", "data.temperature"],
                                "fontSize": 26,
                                "fontWeight": "bold",
                                "color": "onSurface"
                            }
                        ]
                    },
                    {
                        "type": "spacer",
                        "flex": 1
                    },
                    {
                        "type": "column",
                        "alignment": "end",
                        "crossAlignment": "end",
                        "children": [
                            {
                                "type": "image",
                                "src": ["get", "data.iconPath"],
                                "size": 54,
                                "visibleIf": ["has", "data.iconPath"]
                            },
                            {
                                "type": "label",
                                "text": ["get", "data.description"],
                                "fontSize": 11,
                                "color": "onSurfaceVariant",
                                "textAlign": "right",
                                "maxLines": 1,
                                "visibleIf": ["has", "data.description"]
                            }
                        ]
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 8
            },
            {
                "type": "row",
                "alignment": "start",
                "crossAlignment": "start",
                "fillWidth": true,
                "paddingHorizontal": 8,
                "children": [
                    {
                        "type": "label",
                        "text": "hourly",
                        "textAlign": "left",
                        "fontSize": 12,
                        "fontWeight": "medium",
                        "color": "onSurfaceVariant"
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 4
            },
            {
                "type": "scrollView",
                "direction": "horizontal",
                "showIndicators": false,
                "children": [
                    {
                        "type": "row",
                        "spacing": 0,
                        "children": [
                            {
                                "type": "forEach",
                                "items": "hourlyData",
                                "limit": 8,
                                "itemTemplate": {
                                    "type": "column",
                                    "alignment": "center",
                                    "crossAlignment": "center",
                                    "width": 53,
                                    "spacing": 2,
                                    "paddingHorizontal": 4,
                                    "children": [
                                        {
                                            "type": "label",
                                            "text": ["get", "item.time"],
                                            "fontSize": 10,
                                            "color": "onSurfaceVariant",
                                            "maxLines": 1
                                        },
                                        {
                                            "type": "image",
                                            "src": ["get", "item.iconPath"],
                                            "size": 28
                                        },
                                        {
                                            "type": "label",
                                            "text": ["get", "item.temperature"],
                                            "fontSize": 12,
                                            "fontWeight": "bold",
                                            "color": "onSurface",
                                            "maxLines": 1
                                        },
                                        {
                                            "type": "label",
                                            "text": ["get", "item.precipAccumulation"],
                                            "fontSize": 9,
                                            "color": "onSurfaceVariant",
                                            "visibleIf": ["has", "item.precipAccumulation"]
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 8
            },
            {
                "type": "row",
                "alignment": "start",
                "crossAlignment": "start",
                "fillWidth": true,
                "paddingHorizontal": 8,
                "children": [
                    {
                        "type": "label",
                        "text": "daily",
                        "textAlign": "left",
                        "fontSize": 12,
                        "fontWeight": "medium",
                        "color": "onSurfaceVariant"
                    }
                ]
            },
            {
                "type": "spacer",
                "size": 4
            },
            {
                "type": "scrollView",
                "direction": "vertical",
                "showIndicators": false,
                "children": [
                    {
                        "type": "forEach",
                        "items": "dailyData",
                        "limit": 10,
                        "itemTemplate": {
                            "type": "column",
                            "fillWidth": true,
                            "padding": 2,
                            "alignment": "center",
                            "crossAlignment": "center",
                            "children": [
                                {
                                    "type": "column",
                                    "fillWidth": true,
                                    "paddingHorizontal": 6,
                                    "paddingVertical": 2,
                                    "backgroundColor": "surfaceVariant",
                                    "cornerRadius": 8,
                                    "alignment": "center",
                                    "crossAlignment": "center",
                                    "children": [
                                        {
                                            "type": "row",
                                            "fillWidth": true,
                                            "alignment": "center",
                                            "crossAlignment": "center",
                                            "children": [
                                                {
                                                    "type": "label",
                                                    "text": ["get", "item.day"],
                                                    "fontSize": 12,
                                                    "fontWeight": "medium",
                                                    "color": "onSurface",
                                                    "maxLines": 1
                                                },
                                                {
                                                    "type": "spacer",
                                                    "flex": 1
                                                },
                                                {
                                                    "type": "image",
                                                    "src": ["get", "item.iconPath"],
                                                    "size": 36
                                                },
                                                {
                                                    "type": "spacer",
                                                    "flex": 1
                                                },
                                                {
                                                    "type": "column",
                                                    "alignment": "end",
                                                    "crossAlignment": "end",
                                                    "children": [
                                                        {
                                                            "type": "row",
                                                            "alignment": "end",
                                                            "crossAlignment": "center",
                                                            "spacing": 6,
                                                            "children": [
                                                                {
                                                                    "type": "label",
                                                                    "text": ["get", "item.temperatureHigh"],
                                                                    "fontSize": 13,
                                                                    "fontWeight": "bold",
                                                                    "color": "onSurface",
                                                                    "maxLines": 1
                                                                },
                                                                {
                                                                    "type": "label",
                                                                    "text": ["get", "item.temperatureLow"],
                                                                    "fontSize": 11,
                                                                    "color": "onSurfaceVariant",
                                                                    "maxLines": 1
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "type": "row",
                                                            "alignment": "end",
                                                            "crossAlignment": "center",
                                                            "spacing": 6,
                                                            "children": [
                                                                {
                                                                    "type": "label",
                                                                    "text": ["get", "item.precipAccumulation"],
                                                                    "fontSize": 10,
                                                                    "color": "onSurfaceVariant",
                                                                    "visibleIf": ["has", "item.precipAccumulation"]
                                                                },
                                                                {
                                                                    "type": "label",
                                                                    "text": ["concat", "\ud83d\udca7", ["get", "item.precipitation"]],
                                                                    "fontSize": 10,
                                                                    "color": "onSurfaceVariant",
                                                                    "visibleIf": ["has", "item.precipitation"]
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                ]
            }
        ]
    },
    "generatePreviews": true,
    "preview": {
        "sizes": [
            {"width": 160, "height": 300},
            {"width": 260, "height": 400}
        ],
        "fakeData": {
