{
    "$schema": "../../schema.json",
    "name": "SimpleWeatherWidget",
    "displayName": "Simple Weather",
    "description": "Shows current temperature, weather icon, and location",
    "supportedSizes": [
        { "width": 50, "height": 50, "family": "small" },
        { "width": 80, "height": 80, "family": "small" },
        { "width": 120, "height": 120, "family": "small" },
        { "width": 260, "height": 120, "family": "medium" }
    ],
    "defaultPadding": 6,
    "background": { "type": "solid", "color": "widgetBackground" },
    "layout": {
        "type": "conditional",
        "condition": ["<", ["get", "size.width"], 120],
        "then": {
            "type": "column",
            "fillWidth": true,
            "fillHeight": true,
            "padding": 3,
            "crossAlignment": "center",
            "children": [
                {
                    "type": "column",
                    "fillWidth": true,
                    "flex": 1,
                    "alignment": "center",
                    "crossAlignment": "center",
                    "children": [
                        {
                            "type": "image",
                            "src": ["get", "iconPath"],
                            "size": ["*", ["get", "size.width"], 0.44],
                            "visibleIf": ["has", "iconPath"]
                        },
                        {
                            "type": "label",
                            "text": ["get", "temperature"],
                            "fontSize": ["*", ["get", "size.width"], 0.2],
                            "fontWeight": "bold",
                            "color": "onSurface"
                        }
                    ]
                },
                {
                    "type": "label",
                    "text": ["get", "locationName"],
                    "fontSize": 8,
                    "color": "onSurfaceVariant",
                    "maxLines": 1
                }
            ]
        },
        "else": {
            "type": "stack",
            "fillWidth": true,
            "fillHeight": true,
            "padding": 6,
            "children": [
                {
                    "type": "label",
                    "text": ["get", "locationName"],
                    "fontSize": 12,
                    "color": "onSurfaceVariant",
                    "maxLines": 1
                },
                {
                    "type": "row",
                    "fillWidth": true,
                    "fillHeight": true,
                    "alignment": "start",
                    "children": [
                        {
                            "type": "column",
                            "fillHeight": true,
                            "alignment": "center",
                            "crossAlignment": "start",
                            "children": [
                                {
                                    "type": "label",
                                    "text": ["get", "temperature"],
                                    "fontSize": ["min", ["*", ["get", "size.width"], 0.16], 30],
                                    "fontWeight": "bold",
                                    "color": "onSurface"
                                }
                            ]
                        },
                        {
                            "type": "column",
                            "fillHeight": true,
                            "fillWidth": true,
                            "alignment": "center",
                            "crossAlignment": "end",
                            "children": [
                                {
                                    "type": "image",
                                    "src": ["get", "iconPath"],
                                    "size": 64,
                                    "visibleIf": ["has", "iconPath"]
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "stack",
                    "fillWidth": true,
                    "fillHeight": true,
                    "contentAlignment": "BottomEnd",
                    "visibleIf": ["has", "description"],
                    "children": [
                        {
                            "type": "label",
                            "text": ["get", "description"],
                            "fontSize": 12,
                            "color": "onSurfaceVariant",
                            "textAlign": "right"
                        }
                    ]
                }
            ]
        }
    },
    "generatePreviews": true,
    "preview": {
        "sizes": [
            { "width": 50, "height": 50 },
            { "width": 80, "height": 80 },
            { "width": 120, "height": 120 },
            { "width": 260, "height": 120 }
        ],
        "fakeData": {
            "temperature": "8 \u00b0C",
            "iconPath": "icon_themes/weathericons/images/800d.png",
            "description": "Partly Cloudy",
            "locationName": "Grenoble",
            "date": "Mon, Feb 24"
        }
    }
}
