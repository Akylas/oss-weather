{
    "$schema": "../../schema.json",
    "name": "SimpleWeatherWithDateWidget",
    "displayName": "Weather with Date",
    "description": "Shows current date with weather information",
    "defaultPadding": 4,
    "color": ["case", ["==", ["get", "config.settings.color"], null], "color.onSurface", ["get", "config.settings.color"]],
    "settings": {
        "clockBold": { "type": "boolean", "default": false, "title": "bold_clock" }
    },
    "layout": {
        "type": "column",
        "fillMaxSize": true,
        "paddingHorizontal": 10,
        "paddingVertical": 6,
        "alignment": "center",
        "children": [
            {
                "type": "row",
                "fillWidth": true,
                "children": [
                    {
                        "type": "label",
                        "alignment": "bottom",
                        "text": ["get", "locationName"],
                        "fontSize": 12,
                        "opacity": 0.5,
                        "maxLines": 1
                    },
                    {
                        "type": "label",
                        "alignment": "bottom",
                        "flex": 1,
                        "text": ["get", "temperature"],
                        "fontSize": ["min", ["*", ["get", "size.width"], 0.2], 20],
                        "fontWeight": "bold",
                        "textAlign": "right"
                    }
                ]
            },
            {
                "type": "row",
                "fillWidth": true,
                "crossAlignment": "center",
                "children": [
                    {
                        "type": "date",
                        "style": "dayMonth",
                        "fontSize": ["min", ["*", ["get", "size.width"], 0.17], 62],
                        "fontWeight": ["case", ["==", ["get", "config.settings.clockBold"], true], "bold", "normal"]
                    },
                    {
                        "type": "spacer",
                        "flex": 1
                    },
                    {
                        "type": "image",
                        "src": ["get", "iconPath"],
                        "crossAlignment": "end",
                        "size": ["min", ["case", [">=", ["get", "size.height"], 200], ["*", ["get", "size.height"], 0.52], ["*", ["get", "size.width"], 0.27]], 100],
                        "visibleIf": ["has", "iconPath"]
                    }
                ]
            },
            {
                "type": "row",
                "fillWidth": true,
                "children": [
                    {
                        "type": "date",
                        "style": "year",
                        "fontSize": 14,
                        "opacity": 0.5
                    },
                    {
                        "type": "label",
                        "flex": 1,
                        "text": ["get", "description"],
                        "fontSize": 12,
                        "opacity": 0.5,
                        "visibleIf": ["has", "description"],
                        "textAlign": "right"
                    }
                ]
            }
        ]
    },
    "generatePreviews": true,
    "preview": {
        "sizes": [
            { "width": 260, "height": 140 },
            { "width": 120, "height": 50 },
            { "width": 80, "height": 80 },
            { "width": 120, "height": 120 }
        ],
        "fakeData": {
            "temperature": "8\u00b0",
            "iconPath": "800d",
            "description": "Partly Cloudy",
            "locationName": "Grenoble",
            "date": "Mon, Feb 24"
        }
    }
}
