{
    "$schema": "../schema.json",
    "name": "SimpleWeatherWithDateWidget",
    "displayName": "Weather with Date",
    "description": "Shows current date with weather information",
    "supportedSizes": [
        { "width": 120, "height": 50, "family": "small" },
        { "width": 80, "height": 80, "family": "small" },
        { "width": 120, "height": 120, "family": "small" },
        { "width": 260, "height": 120, "family": "medium" }
    ],
    "defaultPadding": 4,
    "background": { "type": "solid", "color": "widgetBackground" },
    "settings": {
        "clockBold": { "type": "boolean", "default": true, "title": "Bold clock" }
    },
    "layout": {
        "type": "conditional",
        "condition": [">=", ["get", "size.width"], 180],
        "then": {
            "type": "stack",
            "fillMaxSize": true,
            "padding": 4,
            "children": [
                {
                    "type": "row",
                    "fillWidth": true,
                    "fillHeight": true,
                    "padding": 8,
                    "alignment": "start",
                    "crossAlignment": "center",
                    "children": [
                        {
                            "type": "column",
                            "alignment": "start",
                            "crossAlignment": "start",
                            "children": [
                                {
                                    "type": "clock",
                                    "fontSize": 48,
                                    "fontWeight": "config.settings.clockBold",
                                    "color": "onSurface"
                                },
                                {
                                    "type": "spacer",
                                    "size": 4
                                },
                                {
                                    "type": "date",
                                    "style": "date",
                                    "fontSize": 14,
                                    "color": "onSurfaceVariant"
                                }
                            ]
                        },
                        {
                            "type": "spacer",
                            "flex": 1
                        },
                        {
                            "type": "column",
                            "alignment": "center",
                            "crossAlignment": "center",
                            "children": [
                                {
                                    "type": "image",
                                    "src": ["get", "iconPath"],
                                    "size": 62,
                                    "visibleIf": ["has", "iconPath"]
                                },
                                {
                                    "type": "label",
                                    "text": ["get", "temperature"],
                                    "fontSize": ["min", ["*", ["get", "size.width"], 0.2], 15],
                                    "fontWeight": "bold",
                                    "color": "onSurface",
                                    "textAlign": "right"
                                },
                                {
                                    "type": "label",
                                    "text": ["get", "description"],
                                    "fontSize": ["min", ["*", ["get", "size.width"], 0.04], 15],
                                    "color": "onSurface",
                                    "textAlign": "right"
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "column",
                    "fillWidth": true,
                    "alignment": "end",
                    "crossAlignment": "start",
                    "children": [
                        {
                            "type": "label",
                            "text": ["get", "locationName"],
                            "fontSize": 12,
                            "color": "onSurfaceVariant",
                            "maxLines": 1
                        }
                    ]
                }
            ]
        },
        "else": {
            "type": "stack",
            "fillMaxSize": true,
            "padding": 3,
            "children": [
                {
                    "type": "column",
                    "fillMaxSize": true,
                    "paddingTop": ["case", ["<=", ["get", "size.height"], 50], 0, 10],
                    "alignment": "start",
                    "crossAlignment": "center",
                    "children": [
                        {
                            "type": "column",
                            "fillWidth": true,
                            "crossAlignment": ["case", ["<=", ["get", "size.height"], 50], "end", "center"],
                            "children": [
                                {
                                    "type": "clock",
                                    "fontSize": ["min", ["*", ["get", "size.height"], 0.24], 40],
                                    "fontWeight": "config.settings.clockBold",
                                    "color": "onSurface",
                                    "textAlign": ["case", ["<=", ["get", "size.height"], 50], "right", "left"]
                                }
                            ]
                        },
                        {
                            "type": "row",
                            "alignment": "center",
                            "crossAlignment": "center",
                            "children": [
                                {
                                    "type": "image",
                                    "src": ["get", "iconPath"],
                                    "size": ["case", ["<", ["get", "size.width"], 100], 32, ["<", ["get", "size.width"], 150], 40, 56],
                                    "visibleIf": ["has", "iconPath"]
                                },
                                {
                                    "type": "spacer",
                                    "direction": "horizontal",
                                    "size": ["case", ["<", ["get", "size.width"], 100], 4, ["<", ["get", "size.width"], 150], 6, 8]
                                },
                                {
                                    "type": "label",
                                    "text": ["get", "temperature"],
                                    "fontSize": ["min", ["*", ["get", "size.width"], 0.2], 20],
                                    "fontWeight": "bold",
                                    "color": "onSurface"
                                }
                            ]
                        },
                        {
                            "type": "spacer",
                            "size": ["case", ["<", ["get", "size.width"], 100], 2, ["<", ["get", "size.width"], 150], 4, 8]
                        },
                        {
                            "type": "spacer",
                            "size": ["case", ["<", ["get", "size.width"], 100], 4, ["<", ["get", "size.width"], 150], 6, 8]
                        }
                    ]
                },
                {
                    "type": "column",
                    "alignment": "end",
                    "crossAlignment": "end",
                    "children": [
                        {
                            "type": "spacer",
                            "flex": 1
                        },
                        {
                            "type": "label",
                            "text": ["get", "locationName"],
                            "fontSize": ["case", ["<", ["get", "size.width"], 100], 8, ["<", ["get", "size.width"], 150], 10, 12],
                            "color": "onSurfaceVariant",
                            "maxLines": 1
                        }
                    ]
                }
            ]
        }
    },
    "generatePreviews": true,
    "preview": {
        "sizes": [
            { "width": 120, "height": 50 },
            { "width": 80, "height": 80 },
            { "width": 120, "height": 120 },
            { "width": 260, "height": 120 }
        ],
        "fakeData": {
            "temperature": "8 \u00b0C",
            "iconPath": "icon_themes/meteocons/images/800d.png",
            "description": "Partly Cloudy",
            "locationName": "Grenoble",
            "date": "Mon, Feb 24"
        }
    }
}
